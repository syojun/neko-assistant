# Dify API連携用の設定
# このファイルをコピーして .env を作成し、実際の値を設定してください

# DifyのAPIベースURL（Difyのアプリ詳細画面で確認できます）
# 例: https://api.dify.ai/v1 または セルフホストの場合は https://your-dify-domain.com/v1
VITE_DIFY_API_BASE_URL=https://api.dify.ai/v1

# DifyのAPIキー（Difyのアプリ詳細 → APIアクセス → APIキー で取得）
# 重要: .env は .gitignore に含め、APIキーをリポジトリにコミットしないでください
VITE_DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx
